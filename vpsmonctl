#!/usr/bin/env python3
import os
import re
import sys
import time
import shutil
import subprocess
import importlib.util
from pathlib import Path

BASE = Path("/opt/vps-monitor")
MONITOR = BASE / "monitor.py"
ENV = BASE / ".env"
STATE = BASE / "state.json"
SERVICE = "vps-monitor.service"


def die(msg, code=1):
    print(f"[ERROR] {msg}", file=sys.stderr)
    sys.exit(code)


def sh(cmd, check=True):
    p = subprocess.run(cmd, shell=True, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
    if check and p.returncode != 0:
        print(p.stdout)
        die(f"command failed: {cmd}", p.returncode)
    return p.stdout


def require_project():
    if not BASE.exists():
        die(f"project dir not found: {BASE}")
    if not MONITOR.exists():
        die(f"monitor.py not found: {MONITOR}")


def backup(label="manual"):
    require_project()
    ts = time.strftime("%Y%m%d%H%M%S")
    made = []
    for p in [MONITOR, ENV, STATE]:
        if p.exists():
            dst = p.with_name(p.name + f".bak.vpsmonctl_{label}_{ts}")
            shutil.copy2(p, dst)
            made.append(str(dst))
    print("[OK] backup created:")
    for x in made:
        print("  " + x)
    return made


def load_env_lines():
    if not ENV.exists():
        return []
    return ENV.read_text(encoding="utf-8", errors="replace").splitlines()


def parse_env():
    kv = {}
    for line in load_env_lines():
        s = line.strip()
        if not s or s.startswith("#") or "=" not in s:
            continue
        k, v = s.split("=", 1)
        v = v.strip().strip('"').strip("'")
        kv[k.strip()] = v
    return kv


def write_env_vars(mapping, label="env"):
    backup(label)
    lines = load_env_lines()
    keys = set(mapping)
    seen = set()
    out = []
    for line in lines:
        matched = False
        for key in keys:
            if re.match(rf"^\s*#?\s*{re.escape(key)}\s*=", line):
                matched = True
                if key not in seen:
                    out.append(f"{key}={mapping[key]}")
                    seen.add(key)
                break
        if not matched:
            out.append(line)
    for key, value in mapping.items():
        if key not in seen:
            if out and out[-1].strip():
                out.append("")
            out.append(f"{key}={value}")
    ENV.write_text("\n".join(out) + "\n", encoding="utf-8")
    ENV.chmod(0o600)
    print("[OK] .env updated:")
    for k, v in mapping.items():
        if any(x in k.upper() for x in ["TOKEN", "KEY", "SECRET"]):
            print(f"  {k}=***")
        else:
            print(f"  {k}={v}")


def load_runtime_env():
    for line in load_env_lines():
        s = line.strip()
        if not s or s.startswith("#") or "=" not in s:
            continue
        k, v = s.split("=", 1)
        os.environ[k.strip()] = v.strip().strip('"').strip("'")


def import_monitor():
    require_project()
    load_runtime_env()
    spec = importlib.util.spec_from_file_location("vps_monitor_runtime", str(MONITOR))
    m = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(m)
    return m


def restart_service():
    require_project()
    print("[INFO] checking python syntax...")
    sh(f"python3 -m py_compile {MONITOR}")
    print("[INFO] restarting service...")
    sh(f"systemctl daemon-reload && systemctl restart {SERVICE}")
    time.sleep(2)
    print(sh(f"systemctl is-active {SERVICE}", check=False).strip())
    print(sh(f"systemctl --no-pager -l status {SERVICE} | sed -n '1,18p'", check=False))


def status():
    require_project()
    print("== service ==")
    print(sh(f"systemctl is-active {SERVICE}", check=False).strip())
    print(sh(f"systemctl --no-pager -l status {SERVICE} | sed -n '1,18p'", check=False))
    print("== recent logs ==")
    print(sh(f"journalctl -u {SERVICE} -n 40 --no-pager", check=False))


def logs(n="80"):
    try:
        n = int(n)
    except ValueError:
        n = 80
    n = max(10, min(n, 500))
    print(sh(f"journalctl -u {SERVICE} -n {n} --no-pager", check=False))


def mask_id(x):
    x = str(x)
    if len(x) <= 6:
        return x
    return x[:3] + "***" + x[-4:]


def split_ids(raw):
    ids = []
    for part in re.split(r"[,;\s]+", raw or ""):
        part = part.strip()
        if part and part not in ids:
            ids.append(part)
    return ids


def list_chats():
    kv = parse_env()
    ids = []
    ids += split_ids(kv.get("TELEGRAM_CHAT_IDS", ""))
    ids += split_ids(kv.get("TELEGRAM_CHAT_ID", ""))
    dedup = []
    for x in ids:
        if x not in dedup:
            dedup.append(x)
    print("Telegram chat ids:")
    for x in dedup:
        print("  " + mask_id(x))


def add_chat(chat_id):
    if not re.fullmatch(r"-?\d{5,20}", chat_id):
        die("invalid Telegram chat id")
    kv = parse_env()
    ids = []
    ids += split_ids(kv.get("TELEGRAM_CHAT_IDS", ""))
    ids += split_ids(kv.get("TELEGRAM_CHAT_ID", ""))
    if chat_id not in ids:
        ids.append(chat_id)
    write_env_vars({"TELEGRAM_CHAT_IDS": ",".join(ids)}, "addchat")
    restart_service()
    test_push(f"✅ #vps-monitor\n已添加 Telegram 推送接收人：<code>{chat_id}</code>")


def validate_price(x):
    if not re.fullmatch(r"\d+(\.\d+)?", x):
        die("price must be number, like 0.1 or 0.4")
    v = float(x)
    if not (0 <= v <= 100):
        die("price out of range")
    return x


def set_cheap_max(value):
    value = validate_price(value)
    write_env_vars({"SITE_A_CHEAP_MAX_PRICE": value}, "setcheap")
    restart_service()


def set_optimized_max(value):
    value = validate_price(value)
    write_env_vars({"SITE_A_MAX_PRICE": value}, "setopt")
    restart_service()


def set_interval(value):
    if not re.fullmatch(r"\d+", value):
        die("interval must be integer seconds")
    v = int(value)
    if not (15 <= v <= 3600):
        die("interval should be 15~3600 seconds")
    write_env_vars({"POLL_INTERVAL": str(v), "SITE_A_POLL_INTERVAL": str(v)}, "setinterval")
    restart_service()


def set_keywords(csv_text):
    csv_text = csv_text.strip()
    if not csv_text:
        die("keywords cannot be empty")
    write_env_vars({"SITE_A_OPTIMIZED_KEYWORDS": csv_text}, "setkeywords")
    restart_service()


def set_exclude_keywords(csv_text):
    csv_text = csv_text.strip()
    if not csv_text:
        die("exclude keywords cannot be empty")
    write_env_vars({"SITE_A_OPTIMIZED_EXCLUDE_KEYWORDS": csv_text}, "setexcludekeywords")
    restart_service()


def only_changes(value):
    v = value.lower()
    if v in ["on", "true", "1", "yes"]:
        final = "true"
    elif v in ["off", "false", "0", "no"]:
        final = "false"
    else:
        die("usage: vpsmonctl only-changes on|off")
    write_env_vars({"NOTIFY_ONLY_CHANGES": final}, "onlychanges")
    restart_service()


def check():
    m = import_monitor()
    items, total = m.fetch_site_a()
    opt = [p for p in items if m._site_a_price_in_range(p) and m._site_a_has_optimized_route(p)]
    cheap = [p for p in items if m._site_a_price_in_cheap_any_range(p)]
    union = [p for p in items if m._site_a_match_rules(p)]
    avail = [p for p in union if m._site_a_stock_available(p)]
    print("独角鲸云检查：")
    print(f"  total={total}")
    print(f"  plans={len(items)}")
    print(f"  0~{m.SITE_A_MAX_PRICE:g} 优化机={len(opt)}")
    print(f"  0~{m.SITE_A_CHEAP_MAX_PRICE:g} 随便机={len(cheap)}")
    print(f"  union={len(union)}")
    print(f"  available={len(avail)}")


def test_push(text=None):
    m = import_monitor()
    if text is None:
        text = "✅ #vps-monitor\n测试推送成功。"
    ok = m.send_tg(text)
    print(f"[OK] test_push={ok}")


def manual_push():
    m = import_monitor()
    items, total = m.fetch_site_a()
    available = [p for p in items if m._site_a_available(p)]
    available.sort(key=lambda p: (float(p.get("price_monthly") or 999), str(p.get("machine_region") or ""), str(p.get("machine_name") or ""), str(p.get("name") or "")))

    def formatter(plans):
        by_mer = m._site_a_group_by_mer(plans)
        parts = [
            "📣 #独角鲸云 #手动推送 #当前可购买",
            f"🎯 规则：0~{m.SITE_A_MAX_PRICE:g} USD/月优化机，或 0~{m.SITE_A_CHEAP_MAX_PRICE:g} USD/月随便机",
            f"📦 本页：<b>{len(by_mer)}</b> 商家 / <b>{len(plans)}</b> 套餐；当前总可购买：<b>{len(available)}</b> 套餐",
        ]
        for mer, plist in by_mer.items():
            parts.append(f"\n<b>📍 {m._html_escape(mer)}</b> ({len(plist)} 个)")
            for p in plist[:10]:
                parts.append(m._site_a_format(p))
            if len(plist) > 10:
                parts.append(f"  · ... +{len(plist) - 10} 个")
        parts.append(m._site_a_footer())
        return "\n".join(parts)

    if not available:
        m.send_tg("📣 #独角鲸云 #手动推送\n当前没有命中规则且可购买的库存。" + m._site_a_footer())
        print(f"[OK] manual push: available=0 total={total}")
        return

    m._paginate_push("📣 #独角鲸云 #手动推送 #当前可购买", available, formatter, page_size=8)
    pages = (len(available) + 7) // 8
    print(f"[OK] manual push: available={len(available)} total={total} pages={pages}")


def usage():
    print("""vpsmonctl - vps-monitor 控制器

用法：
  vpsmonctl status
  vpsmonctl logs [N]
  vpsmonctl restart
  vpsmonctl backup [label]
  vpsmonctl check
  vpsmonctl list-chats
  vpsmonctl add-chat CHAT_ID
  vpsmonctl set-cheap-max PRICE
  vpsmonctl set-optimized-max PRICE
  vpsmonctl set-interval SECONDS
  vpsmonctl set-keywords CSV
  vpsmonctl set-exclude-keywords CSV
  vpsmonctl only-changes on|off
  vpsmonctl manual-push
  vpsmonctl test-push [TEXT]
""")


def main():
    if len(sys.argv) < 2:
        usage(); return
    cmd = sys.argv[1]
    if cmd == "status": status()
    elif cmd == "logs": logs(sys.argv[2] if len(sys.argv) > 2 else "80")
    elif cmd == "restart": restart_service()
    elif cmd == "backup": backup(sys.argv[2] if len(sys.argv) > 2 else "manual")
    elif cmd == "check": check()
    elif cmd == "list-chats": list_chats()
    elif cmd == "add-chat":
        if len(sys.argv) < 3: die("usage: vpsmonctl add-chat CHAT_ID")
        add_chat(sys.argv[2])
    elif cmd == "set-cheap-max":
        if len(sys.argv) < 3: die("usage: vpsmonctl set-cheap-max PRICE")
        set_cheap_max(sys.argv[2])
    elif cmd == "set-optimized-max":
        if len(sys.argv) < 3: die("usage: vpsmonctl set-optimized-max PRICE")
        set_optimized_max(sys.argv[2])
    elif cmd == "set-interval":
        if len(sys.argv) < 3: die("usage: vpsmonctl set-interval SECONDS")
        set_interval(sys.argv[2])
    elif cmd == "set-keywords":
        if len(sys.argv) < 3: die("usage: vpsmonctl set-keywords CSV")
        set_keywords(" ".join(sys.argv[2:]))
    elif cmd == "set-exclude-keywords":
        if len(sys.argv) < 3: die("usage: vpsmonctl set-exclude-keywords CSV")
        set_exclude_keywords(" ".join(sys.argv[2:]))
    elif cmd == "only-changes":
        if len(sys.argv) < 3: die("usage: vpsmonctl only-changes on|off")
        only_changes(sys.argv[2])
    elif cmd == "manual-push": manual_push()
    elif cmd == "test-push": test_push(" ".join(sys.argv[2:]) if len(sys.argv) > 2 else None)
    else:
        usage(); die(f"unknown command: {cmd}")

if __name__ == "__main__":
    main()

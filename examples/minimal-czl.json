{
  "state_db": "./state/vpsmon.sqlite3",
  "sources": {
    "czl": {
      "enabled": true,
      "api_url": "https://vps-monitor.czl.net/api/public/filter",
      "deploy_url": "https://vps-monitor.czl.net/buy/{item_id}",
      "page_size": 12,
      "max_pages": 20,
      "max_workers": 4
    },
    "dujiaojing": {
      "enabled": false,
      "api_url": "https://api.fuckip.me/api/v1/plans",
      "token_env": "SITE_A_TOKEN",
      "deploy_url": "https://dash.fuckip.me/deploy?plan_id={plan_id}&machine_id={machine_id}&region={region}",
      "page_size": 200,
      "max_pages": 10
    }
  },
  "rules": {
    "global": {
      "exclude_keywords": ["dedicated", "dedi", "独立服", "独立服务器"]
    },
    "czl": {
      "price_min_usd_year": 1,
      "price_max_usd_year": 30,
      "pools": [
        {
          "name": "入门低价",
          "ram_min_gb": 0.4,
          "ram_max_gb": 1.0,
          "usd_year_min": 0,
          "usd_year_max": 10
        }
      ]
    }
  },
  "notify_policy": {
    "default": {
      "limit_events": 5,
      "sort_events": "pool_price"
    }
  },
  "telegram": {
    "enabled": false,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_ids_env": "TELEGRAM_CHAT_IDS",
    "disable_web_page_preview": true
  }
}

{
  "state_db": "./state/vpsmon.sqlite3",
  "sources": {
    "czl": {
      "enabled": true,
      "api_url": "https://vps-monitor.czl.net/api/public/filter",
      "page_size": 12,
      "max_pages": 100,
      "max_workers": 8,
      "deploy_url": "https://vps-monitor.czl.net/buy/{item_id}"
    },
    "dujiaojing": {
      "enabled": true,
      "api_url": "https://api.fuckip.me/api/v1/plans",
      "token_env": "SITE_A_TOKEN",
      "deploy_url": "https://dash.fuckip.me/deploy?plan_id={plan_id}&machine_id={machine_id}&region={region}",
      "page_size": 200,
      "max_pages": 50
    }
  },
  "rules": {
    "global": {
      "exclude_keywords": [
        "dedicated",
        "dedi",
        "独立服",
        "独立服务器"
      ]
    },
    "czl": {
      "price_min_usd_year": 1,
      "price_max_usd_year": 70,
      "monthly_price_max_usd": 10,
      "pools": [
        {
          "name": "池1(廉价)",
          "ram_min_gb": 0.4,
          "ram_max_gb": 1.0,
          "usd_year_min": 0,
          "usd_year_max": 10
        },
        {
          "name": "池2(主力)",
          "ram_min_gb": 1.0,
          "ram_max_gb": 16.0,
          "usd_year_min": 10,
          "usd_year_max": 20
        }
      ]
    },
    "dujiaojing": {
      "price_max_usd_month": 0.3,
      "pools": [
        {
          "name": "超低价",
          "ram_min_gb": 0,
          "ram_max_gb": 1024,
          "usd_year_min": 0,
          "usd_year_max": 0.96
        },
        {
          "name": "优化线路",
          "ram_min_gb": 0,
          "ram_max_gb": 1024,
          "usd_year_min": 0,
          "usd_year_max": 3.6
        }
      ]
    }
  },
  "notify_policy": {
    "default": {
      "limit_events": 12,
      "sort_events": "pool_price"
    },
    "dujiaojing": {
      "limit_events": 12,
      "sort_events": "pool_price"
    },
    "czl": {
      "limit_events": 20,
      "sort_events": "pool_price"
    }
  },
  "telegram": {
    "enabled": false,
    "bot_token_env": "TELEGRAM_BOT_TOKEN",
    "chat_ids_env": "TELEGRAM_CHAT_IDS",
    "disable_web_page_preview": true
  }
}

# ========================================
# VPS Monitor 环境变量模板
# 复制为 .env 并填入真实值(.env 不会进 git)
# ========================================

# -------- Telegram --------
TELEGRAM_BOT_TOKEN=1102015432:AAH_your_token_here
TELEGRAM_CHAT_IDS=123456789,987654321
# 多个 chat_id 用英文逗号分隔,单点失败不影响其他

# -------- Site A: WHMCS Bearer Token --------
SITE_A_NAME=dartnode
SITE_A_API_URL=https://api.example.com/api/v1/plans
SITE_A_TOKEN=eyJ_your_jwt_here
SITE_A_POLL_INTERVAL=60
SITE_A_OPTIMIZED_MAX=0.4
SITE_A_CHEAP_MAX=0.1

# -------- Site B: 公开 API --------
SITE_B_NAME=public_whmcs
SITE_B_API_URL=https://api.example.com/api/v2/packages
SITE_B_POLL_INTERVAL=90

# -------- Site C: 资源模板 API --------
SITE_C_NAME=incudal
SITE_C_API_URL=https://api.example.com/api/packages
SITE_C_TOKEN=eyJ_your_jwt_here
SITE_C_POLL_INTERVAL=90

# -------- Site D: HTML 解析 --------
SITE_D_NAME=dedirock
SITE_D_URL=https://example.com/promo
SITE_D_POLL_INTERVAL=300

# Site E (czl.net 公开 API, 1C2G 池监控, 2026-06-20 加)
# 数据源: https://vps-monitor.czl.net/api/public/filter (公开 API, 无 token)
# 池规则: 池1 (RAM 0.4-1.1GB + ≤$9/年) + 池2 (RAM 2-16GB + $10-20/年)
# 排除: DEDI / 独立服务器; 无三网优化过滤 (per user)
SITE_E_NAME=vps-monitor-czl
SITE_E_API_URL=https://vps-monitor.czl.net/api/public/filter
SITE_E_POLL_INTERVAL=7200
SITE_E_DEPLOY_URL=https://vps-monitor.czl.net/buy/{plan_id}

# -------- 全局 --------
LOG_LEVEL=INFO
MAIN_LOOP_INTERVAL=60
